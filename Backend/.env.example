# ──────────────────────────────────────────────────────
# Bigkas Backend — Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────

# JWT (must match your Supabase project's JWT secret — used to verify tokens)
JWT_SECRET=your-jwt-secret
JWT_ALGORITHM=HS256

# For hosted Supabase RS256 tokens, JWTs are verified via JWKS fetched from SUPABASE_URL.
# Keep SUPABASE_URL set in production/Hugging Face.

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000,http://localhost:19006,exp://localhost:8081

# Audio processing limits
MAX_AUDIO_DURATION_SEC=120
MAX_UPLOAD_SIZE_MB=25

# Supabase (required for exponential login backoff)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI API Keys (server-side script generation with rate limiting)
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key

# Hugging Face ASR (Whisper model on Hub)
HF_WHISPER_MODEL_ID=openai/whisper-tiny
